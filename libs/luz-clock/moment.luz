# moment.luz — Current date and time

# Returns a dict with all components of the current local time:
#   year, month, day, hour, min, sec, ms, weekday (0=Mon), yearday
function now() {
    return _clock_now()
}

# Returns only the date part: {year, month, day}
function today() {
    t = _clock_now()
    return {"year": t["year"], "month": t["month"], "day": t["day"]}
}

# Returns only the time part: {hour, min, sec, ms}
function current_time() {
    t = _clock_now()
    return {"hour": t["hour"], "min": t["min"], "sec": t["sec"], "ms": t["ms"]}
}

# Returns the current Unix timestamp (seconds since 1970-01-01)
function stamp() {
    return _clock_stamp()
}
